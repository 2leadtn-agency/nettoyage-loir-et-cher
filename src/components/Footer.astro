---
import Sparkle from "./Sparkle.astro";

// TODO: numéro de téléphone réel à ajouter (non fourni par le client)
const PHONE_DISPLAY = "02 00 00 00 00";
const PHONE_TEL = "+33200000000";
const EMAIL = "contact@nettoyage-loir-et-cher.fr";
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/images/logo.png" alt="Nettoyage Loir et Cher" width="36" height="36" />
        <span>Nettoyage <em>Loir et Cher</em></span>
      </a>
      <p class="footer-tagline">
        Nettoyage professionnel à Blois et dans le Loir-et-Cher. Une équipe soignée, réactive et de
        confiance, pour les entreprises comme pour les particuliers.
      </p>
    </div>

    <div class="footer-col">
      <h3>Services</h3>
      <ul>
        <li><a href="/#services">Nettoyage de bureaux</a></li>
        <li><a href="/#services">Remise en état après travaux</a></li>
        <li><a href="/#services">Nettoyage de vitres</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Contact</h3>
      <ul>
        <li><a href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a></li>
        <li><a href={`mailto:${EMAIL}`}>{EMAIL}</a></li>
        <li>Blois et le Loir-et-Cher (41)</li>
      </ul>
    </div>

    <div class="footer-col">
      <h3>Nettoyage Loir et Cher</h3>
      <ul>
        <li><a href="/#urgence">Intervention urgente</a></li>
        <li><a href="/#zone">Zone d'intervention</a></li>
        <li><a href="/contact">Nous contacter</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p><Sparkle class="footer-sparkle" /> Nettoyage Loir et Cher — Blois (41)</p>
      <p>&copy; {new Date().getFullYear()} Tous droits réservés.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-ink);
    color: rgba(251, 248, 243, 0.75);
    padding: 56px 0 0;
  }

  .footer-inner {
    display: grid;
    gap: 40px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--color-cream);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
  }

  .footer-logo em {
    font-style: normal;
    color: var(--color-gold-light);
  }

  .footer-tagline {
    font-size: 0.92rem;
    max-width: 340px;
    line-height: 1.6;
  }

  .footer-col h3 {
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--color-gold-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col a {
    text-decoration: none;
    color: rgba(251, 248, 243, 0.75);
    font-size: 0.92rem;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--color-gold-light);
  }

  .footer-col li {
    font-size: 0.92rem;
  }

  .footer-bottom {
    margin-top: 44px;
    border-top: 1px solid rgba(251, 248, 243, 0.12);
  }

  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px 0;
    font-size: 0.8rem;
    color: rgba(251, 248, 243, 0.5);
  }

  .footer-bottom-inner p {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  :global(.footer-sparkle) {
    width: 12px;
    height: 12px;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  @media (min-width: 720px) {
    .footer-inner {
      grid-template-columns: 1.6fr 1fr 1fr 1fr;
    }
  }

  @media (min-width: 560px) {
    .footer-bottom-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
