---
// TODO: numéro de téléphone réel à ajouter (non fourni par le client)
const PHONE_DISPLAY = "02 00 00 00 00";
const PHONE_TEL = "+33200000000";
const WHATSAPP_NUMBER = "33600000000";
const PREFILLED_MESSAGE = "Bonjour, je vous contacte depuis votre site";
---

<header class="nav" id="site-nav">
  <div class="container nav-inner">
    <a href="/" class="logo" aria-label="Nettoyage Loir et Cher - Accueil">
      <img src="/images/logo.png" alt="Nettoyage Loir et Cher" width="40" height="40" />
      <span class="logo-text">Nettoyage <em>Loir et Cher</em></span>
    </a>

    <nav class="nav-links" aria-label="Navigation principale">
      <a href="/#services">Services</a>
      <a href="/#urgence">Urgence</a>
      <a href="/#zone">Zone d'intervention</a>
      <a href="/contact">Contact</a>
    </nav>

    <div class="nav-actions">
      <a class="btn-icon btn-call" href={`tel:${PHONE_TEL}`} aria-label="Appeler Nettoyage Loir et Cher">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="19" height="19">
          <path
            d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1v3.6c0 .6-.4 1-1 1C10.6 21.1 2.9 13.4 2.9 3.7c0-.6.4-1 1-1H7.5c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1L6.6 10.8Z"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
        <span class="btn-label">{PHONE_DISPLAY}</span>
      </a>
      <a
        class="btn-icon btn-whatsapp-icon"
        href={`https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(PREFILLED_MESSAGE)}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contacter sur WhatsApp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="19" height="19">
          <path
            d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2Zm0 18.2c-1.6 0-3.1-.4-4.4-1.2l-.3-.2-3.1.8.8-3-.2-.3c-.9-1.4-1.3-3-1.3-4.6C3.5 7.3 7.3 3.5 12 3.5s8.5 3.8 8.5 8.5-3.8 8.2-8.5 8.2Zm4.6-6.3c-.3-.1-1.5-.7-1.7-.8-.2-.1-.4-.1-.6.1-.2.3-.7.8-.8 1-.1.2-.3.2-.5.1-1.4-.7-2.3-1.3-3.2-2.8-.2-.4.2-.4.6-1.2.1-.1 0-.3 0-.4L9.2 8.6c-.1-.2-.3-.2-.5-.2h-.4c-.2 0-.5.1-.7.3-.2.3-.9 1-.9 2.3s1 2.7 1.1 2.9c.1.2 2 3 4.8 4.2.7.3 1.2.5 1.6.6.7.2 1.3.2 1.7.1.5-.1 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.1-.3-.2-.5-.3Z"
          ></path>
        </svg>
        <span class="btn-label">WhatsApp</span>
      </a>
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById("site-nav");
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 12) {
        nav.classList.add("scrolled");
      } else {
        nav.classList.remove("scrolled");
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 500;
    background: rgba(251, 248, 243, 0.92);
    backdrop-filter: blur(8px);
    transition: box-shadow 0.25s ease, background 0.25s ease;
  }

  .nav.scrolled {
    box-shadow: 0 4px 20px rgba(32, 29, 25, 0.1);
    background: rgba(251, 248, 243, 0.98);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    gap: 12px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo img {
    width: 34px;
    height: 34px;
    object-fit: contain;
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--color-ink);
    line-height: 1.1;
    white-space: nowrap;
  }

  .logo-text em {
    font-style: normal;
    color: var(--color-gold-deep);
    display: block;
    font-size: 0.8em;
  }

  .nav-links {
    display: none;
  }

  .nav-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .btn-icon:hover {
    transform: translateY(-2px);
  }

  .btn-label {
    display: none;
  }

  .btn-call {
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .btn-whatsapp-icon {
    background: #25d366;
    color: #fff;
  }

  @media (min-width: 720px) {
    .logo-text {
      font-size: 1.05rem;
    }

    .nav-links {
      display: flex;
      gap: 26px;
      font-weight: 600;
      font-size: 0.92rem;
    }

    .nav-links a {
      text-decoration: none;
      color: var(--color-ink-soft);
      transition: color 0.15s ease;
    }

    .nav-links a:hover {
      color: var(--color-gold-deep);
    }

    .btn-icon {
      width: auto;
      padding: 0 18px;
      border-radius: 999px;
    }

    .btn-label {
      display: inline;
    }
  }
</style>
