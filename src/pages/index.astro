---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Sparkle from "../components/Sparkle.astro";

// TODO: numéro de téléphone et WhatsApp réels à ajouter (non fournis par le client)
const PHONE_DISPLAY = "02 00 00 00 00";
const PHONE_TEL = "+33200000000";
const WHATSAPP_NUMBER = "33600000000";
const PREFILLED_MESSAGE = "Bonjour, je vous contacte depuis votre site";
const WHATSAPP_HREF = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(PREFILLED_MESSAGE)}`;
---

<Layout>
  <Nav />

  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-copy">
          <span class="eyebrow"><Sparkle /> Nettoyage professionnel · Blois &amp; Loir-et-Cher</span>
          <h1>Un nettoyage impeccable, une équipe sur qui compter</h1>
          <p class="hero-subtitle">
            Bureaux, fin de chantier, vitres&nbsp;: à Blois et dans tout le Loir-et-Cher, une petite équipe
            de 4 professionnels prend soin de vos espaces avec rigueur — et répond vite en cas de besoin
            urgent pour les entreprises.
          </p>
          <div class="hero-actions">
            <a class="btn btn-gold" href={`tel:${PHONE_TEL}`}>
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
                <path
                  d="M6.6 10.8c1.4 2.8 3.8 5.2 6.6 6.6l2.2-2.2c.3-.3.7-.4 1.1-.3 1.2.4 2.5.6 3.8.6.6 0 1 .4 1 1v3.6c0 .6-.4 1-1 1C10.6 21.1 2.9 13.4 2.9 3.7c0-.6.4-1 1-1H7.5c.6 0 1 .4 1 1 0 1.3.2 2.6.6 3.8.1.4 0 .8-.3 1.1L6.6 10.8Z"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
              Appeler maintenant
            </a>
            <a class="btn btn-ink" href="/contact">Demander un devis</a>
          </div>
          <ul class="hero-trust">
            <li><Sparkle /> Équipe de 4 professionnels</li>
            <li><Sparkle /> Basés à Blois (41)</li>
            <li><Sparkle /> Réponse rapide en cas d'urgence</li>
          </ul>
        </div>

        <div class="hero-media">
          <img
            src="/images/hero-nettoyage-bureaux-blois.jpg"
            alt="Bureau lumineux et impeccablement nettoyé à Blois"
            width="1200"
            height="900"
            loading="eager"
            fetchpriority="high"
          />
          <span class="hero-sparkle hero-sparkle-1"><Sparkle /></span>
          <span class="hero-sparkle hero-sparkle-2"><Sparkle /></span>
          <span class="hero-sparkle hero-sparkle-3"><Sparkle /></span>
        </div>
      </div>
    </section>

    <!-- URGENCE -->
    <section class="urgence" id="urgence">
      <div class="container urgence-inner">
        <div class="urgence-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="30" height="30">
            <path
              d="M13 2 4 14h6l-1 8 9-12h-6l1-8Z"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </div>
        <div class="urgence-copy">
          <h2>Une urgence professionnelle ? Nous répondons vite.</h2>
          <p>
            Locaux à remettre en état avant une visite, vitrine à nettoyer avant l'ouverture, imprévu à
            traiter dans la journée&nbsp;: les entreprises du Loir-et-Cher nous sollicitent et nous nous
            organisons rapidement pour intervenir.
          </p>
        </div>
        <div class="urgence-actions">
          <a class="btn btn-gold" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
          <a class="btn btn-outline" href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer">
            Écrire sur WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services" id="services">
      <div class="container">
        <span class="eyebrow"><Sparkle /> Nos prestations</span>
        <h2 class="section-title">Trois savoir-faire, une seule exigence de propreté</h2>
        <p class="section-subtitle">
          Que vos locaux accueillent du public, sortent de chantier ou aient simplement besoin d'un entretien
          régulier, nous adaptons notre intervention à votre activité.
        </p>

        <div class="services-grid">
          <article class="service-card">
            <img
              src="/images/service-nettoyage-bureaux.jpg"
              alt="Nettoyage de bureaux professionnel"
              width="640"
              height="480"
              loading="lazy"
            />
            <div class="service-body">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
                  <rect x="3" y="4" width="18" height="13" rx="1.5" stroke="currentColor" stroke-width="1.6"></rect>
                  <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                </svg>
              </div>
              <h3>Nettoyage de bureaux</h3>
              <p>
                Un cadre de travail impeccable, jour après jour. Sols, sanitaires, espaces communs et postes
                de travail entretenus avec discrétion, selon les horaires de votre entreprise.
              </p>
            </div>
          </article>

          <article class="service-card">
            <img
              src="/images/service-fin-de-chantier.jpg"
              alt="Remise en état après travaux, fin de chantier"
              width="640"
              height="480"
              loading="lazy"
            />
            <div class="service-body">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
                  <path
                    d="M4 20 14 10M17 7l3-3M14 5l5 5-9 9-5-1 1-5 8-8Z"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  ></path>
                </svg>
              </div>
              <h3>Remise en état après travaux</h3>
              <p>
                Fin de chantier, dépoussiérage complet, évacuation des résidus&nbsp;: vos locaux retrouvent
                leur éclat et sont prêts à être livrés ou occupés, sans délai.
              </p>
            </div>
          </article>

          <article class="service-card">
            <img
              src="/images/service-nettoyage-vitres.jpg"
              alt="Nettoyage de vitres et vitrines professionnelles"
              width="640"
              height="480"
              loading="lazy"
            />
            <div class="service-body">
              <div class="service-icon">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
                  <rect x="4" y="3" width="16" height="18" rx="1.5" stroke="currentColor" stroke-width="1.6"></rect>
                  <path d="M12 3v18M4 12h16" stroke="currentColor" stroke-width="1.6"></path>
                </svg>
              </div>
              <h3>Nettoyage de vitres</h3>
              <p>
                Vitrines, baies vitrées, bureaux ou façades&nbsp;: un rendu net et sans traces, pour des
                espaces lumineux et soignés en toute saison.
              </p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- EQUIPE -->
    <section class="team">
      <div class="container team-inner">
        <div class="team-media">
          <img
            src="/images/equipe-nettoyage-loir-et-cher.jpg"
            alt="Équipe de Nettoyage Loir et Cher à Blois"
            width="800"
            height="600"
            loading="lazy"
          />
        </div>
        <div class="team-copy">
          <span class="eyebrow"><Sparkle /> Notre équipe</span>
          <h2 class="section-title">Une équipe à taille humaine, au service de vos locaux</h2>
          <p class="section-subtitle">
            Nettoyage Loir et Cher, c'est une équipe de 4 personnes basée à Blois, impliquée et rigoureuse.
            Nous connaissons nos clients, adaptons nos interventions à leurs contraintes et soignons chaque
            détail comme si c'était chez nous.
          </p>
          <ul class="team-list">
            <li><Sparkle /> Rigueur et discrétion</li>
            <li><Sparkle /> Matériel professionnel</li>
            <li><Sparkle /> Disponibilité rapide</li>
            <li><Sparkle /> Un interlocuteur unique</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="process">
      <div class="container">
        <span class="eyebrow"><Sparkle /> Notre méthode</span>
        <h2 class="section-title">Comment ça se passe</h2>

        <div class="process-grid">
          <div class="process-step">
            <span class="process-number">01</span>
            <h3>Vous nous contactez</h3>
            <p>Par téléphone, WhatsApp ou via le formulaire. Nous répondons rapidement, urgence ou non.</p>
          </div>
          <div class="process-step">
            <span class="process-number">02</span>
            <h3>Nous évaluons votre besoin</h3>
            <p>Sur place ou à distance selon la situation, pour vous proposer un devis clair et adapté.</p>
          </div>
          <div class="process-step">
            <span class="process-number">03</span>
            <h3>Nous intervenons</h3>
            <p>À la date convenue, ou en urgence si votre activité l'exige.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ZONE -->
    <section class="zone" id="zone">
      <div class="container zone-inner">
        <span class="eyebrow"><Sparkle /> Zone d'intervention</span>
        <h2 class="section-title">Blois et tout le Loir-et-Cher (41)</h2>
        <p class="section-subtitle">
          Nous intervenons auprès des entreprises et des particuliers dans tout le département, notamment à
        </p>
        <ul class="zone-towns">
          <li>Blois</li>
          <li>Vendôme</li>
          <li>Romorantin-Lanthenay</li>
          <li>Contres</li>
          <li>Selles-sur-Cher</li>
        </ul>
      </div>
    </section>

    <!-- CTA FINALE -->
    <section class="final-cta">
      <div class="container final-cta-inner">
        <h2>Un espace à nettoyer, une urgence à traiter&nbsp;?</h2>
        <p>Parlons de votre besoin — nous vous répondons rapidement.</p>
        <div class="final-cta-actions">
          <a class="btn btn-ink" href={`tel:${PHONE_TEL}`}>{PHONE_DISPLAY}</a>
          <a class="btn btn-whatsapp" href={WHATSAPP_HREF} target="_blank" rel="noopener noreferrer">
            Écrire sur WhatsApp
          </a>
          <a class="btn btn-outline-ink" href="/contact">Formulaire de contact</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero {
    padding: 128px 0 64px;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    gap: 40px;
  }

  .hero-subtitle {
    margin-top: 18px;
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    max-width: 520px;
  }

  h1 {
    font-size: 2.1rem;
    font-weight: 800;
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-trust {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 32px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-ink-soft);
  }

  .hero-trust li {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-trust :global(.sparkle-svg) {
    width: 14px;
    height: 14px;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  .hero-media {
    position: relative;
  }

  .hero-media img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 20px;
    box-shadow: 0 24px 50px rgba(32, 29, 25, 0.18);
  }

  .hero-sparkle {
    position: absolute;
    color: var(--color-gold);
    opacity: 0.85;
  }

  .hero-sparkle :global(.sparkle-svg) {
    display: block;
  }

  .hero-sparkle-1 {
    top: -14px;
    left: 24px;
    width: 26px;
    height: 26px;
  }

  .hero-sparkle-2 {
    bottom: 18px;
    right: -12px;
    width: 34px;
    height: 34px;
  }

  .hero-sparkle-3 {
    top: 40%;
    right: 30px;
    width: 16px;
    height: 16px;
    opacity: 0.6;
  }

  /* URGENCE */
  .urgence {
    background: var(--color-ink);
    color: var(--color-cream);
    padding: 40px 0;
    border-top: 3px solid var(--color-gold);
    border-bottom: 3px solid var(--color-gold);
  }

  .urgence-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .urgence-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(198, 149, 46, 0.15);
    color: var(--color-gold-light);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .urgence-copy h2 {
    color: var(--color-cream);
    font-size: 1.5rem;
    margin-bottom: 10px;
  }

  .urgence-copy p {
    color: rgba(251, 248, 243, 0.78);
    max-width: 620px;
    font-size: 0.98rem;
  }

  .urgence-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 6px;
  }

  /* SERVICES */
  .services {
    padding: 72px 0;
  }

  .services-grid {
    display: grid;
    gap: 24px;
    margin-top: 40px;
  }

  .service-card {
    background: var(--color-white);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(32, 29, 25, 0.07);
    border: 1px solid rgba(32, 29, 25, 0.06);
  }

  .service-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .service-body {
    padding: 24px;
  }

  .service-icon {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: var(--color-gold-pale);
    color: var(--color-gold-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .service-body h3 {
    font-size: 1.2rem;
    margin-bottom: 10px;
  }

  .service-body p {
    color: var(--color-ink-soft);
    font-size: 0.94rem;
  }

  /* TEAM */
  .team {
    padding: 72px 0;
    background: var(--color-cream-alt);
  }

  .team-inner {
    display: grid;
    gap: 36px;
  }

  .team-media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 18px;
  }

  .team-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 22px;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .team-list li {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .team-list :global(.sparkle-svg) {
    width: 14px;
    height: 14px;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  /* PROCESS */
  .process {
    padding: 72px 0;
  }

  .process-grid {
    display: grid;
    gap: 28px;
    margin-top: 40px;
  }

  .process-step {
    padding: 28px 22px;
    border-radius: 16px;
    background: var(--color-white);
    border: 1px solid rgba(32, 29, 25, 0.07);
  }

  .process-number {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-gold);
  }

  .process-step h3 {
    margin: 10px 0;
    font-size: 1.1rem;
  }

  .process-step p {
    color: var(--color-ink-soft);
    font-size: 0.92rem;
  }

  /* ZONE */
  .zone {
    padding: 64px 0;
    background: var(--color-ink);
    color: var(--color-cream);
  }

  .zone .eyebrow {
    color: var(--color-gold-light);
  }

  .zone .section-title {
    color: var(--color-cream);
  }

  .zone .section-subtitle {
    color: rgba(251, 248, 243, 0.72);
  }

  .zone-towns {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }

  .zone-towns li {
    padding: 9px 18px;
    border-radius: 999px;
    border: 1px solid rgba(232, 193, 94, 0.4);
    color: var(--color-gold-light);
    font-size: 0.88rem;
    font-weight: 600;
  }

  /* FINAL CTA */
  .final-cta {
    background: var(--color-gold);
    padding: 64px 0;
  }

  .final-cta-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .final-cta h2 {
    font-size: 1.8rem;
    max-width: 560px;
  }

  .final-cta p {
    margin-top: 12px;
    color: rgba(32, 29, 25, 0.75);
    font-size: 1.05rem;
  }

  .final-cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 28px;
  }

  .btn-outline-ink {
    background: transparent;
    color: var(--color-ink);
    border: 1.5px solid rgba(32, 29, 25, 0.35);
  }

  @media (min-width: 860px) {
    .hero {
      padding: 156px 0 88px;
    }

    .hero-inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: 56px;
    }

    h1 {
      font-size: 2.9rem;
    }

    .urgence-inner {
      flex-direction: row;
      align-items: center;
    }

    .urgence-copy {
      flex: 1;
    }

    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .team-inner {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .process-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .final-cta h2 {
      font-size: 2.3rem;
    }
  }
</style>
